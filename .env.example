# Public Data Portal API key (data.go.kr)
# Obtain from https://www.data.go.kr and paste below
DATA_GO_KR_API_KEY=your_api_key_here

# Optional overrides:
# - odcloud Applyhome (청약홈): by default this project reuses DATA_GO_KR_API_KEY.
#   You can override with either an Authorization header key or a serviceKey query param.
# ODCLOUD_API_KEY=your_odcloud_api_key_here
# ODCLOUD_SERVICE_KEY=your_odcloud_service_key_here
#
# - Onbid next-gen (B010003): by default this project reuses DATA_GO_KR_API_KEY.
# ONBID_API_KEY=your_onbid_api_key_here

# Cloudflare Tunnel token (required for Docker/Cloudflare Tunnel deployment).
# Obtain from Cloudflare Zero Trust → Networks → Tunnels → your tunnel → token.
# See docs/setup-cloudflare.md for setup instructions.
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Deprecated: Caddy reverse proxy (enabled via `docker compose --profile caddy`; see README deprecation notice).
# Use CLOUDFLARE_TUNNEL_TOKEN above instead.
